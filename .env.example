# ── Frontend (bundled — public values only, never secrets) ──────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Browser key: restrict by domain; enable only Maps JavaScript API.
VITE_GOOGLE_MAPS_BROWSER_KEY=
# Data mode: "real" (Supabase + Google) or "demo" (local mock data).
# In production this MUST be "real". Missing real config => config error
# screen, never a silent mock fallback.
VITE_DATA_MODE=demo

# ── Edge Functions (Supabase secrets — set via `supabase secrets set`) ─
# Server key: restrict by API (Places API (New), Geocoding API). Never
# expose in the frontend bundle or logs.
GOOGLE_MAPS_SERVER_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
APP_URL=
APP_ENV=development

# ── Optional enrichment provider ─────────────────────────────────────
ENRICHMENT_PROVIDER=null
ENRICHMENT_API_KEY=
